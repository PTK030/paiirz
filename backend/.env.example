# Copy this file to .env and fill in real values before running.
# Never commit .env to version control.

# Flask secret key - used for session signing. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-before-running

# Optional: server-side salt for Zero-Knowledge IP hashing.
# If left empty, a random salt is generated on every startup (recommended for privacy).
IP_SALT=

# Allowed CORS origins. Use "*" for open access or a comma-separated list:
#   CORS_ALLOWED_ORIGINS=https://yourapp.com,https://www.yourapp.com
CORS_ALLOWED_ORIGINS=*

# Set to "False" in production. Never expose the Werkzeug debugger publicly.
FLASK_DEBUG=False

PORT=5000
